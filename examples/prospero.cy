int SIZE = 512

size("Prospero", SIZE, SIZE)
fill(255, 255, 255)

Image img = Image(SIZE, SIZE)
int index

for int y = 0; y < SIZE; y += 1
  for int x = 0; x < SIZE; x += 1
    float px = x / (SIZE / 2.0) - 1.0
    float py = y / (SIZE / 2.0) - 1.0

    if prospero(px, -py) < 0
      img.data[index] = 255
      img.data[index + 1] = 255
      img.data[index + 2] = 255

    index += 3

void draw(int time)
  img.draw()

float max(float a, float b)
  if a > b
    return a
  else
    return b

float min(float a, float b)
  if a < b
